[node name="TextureRect" type="TextureRect" parent="CanvasLayer"]
visible = false
offset_left = 95.0
offset_top = 584.0
offset_right = 469.0
offset_bottom = 784.0
texture = ExtResource("23_6dkku")

[node name="caocaoLetter2" parent="CanvasLayer" instance=ExtResource("11_1wi74")]
visible = false
offset_left = 995.0
offset_top = 483.0
offset_right = 1035.0
offset_bottom = 523.0
context = "玄德贤弟如晤：
  自陶谦邀弟入徐州，吾即暗中布局。
  曹嵩被害，不过借口；兴师徐州，不过试探；吕布入主，不过引狼入室；弟得徐州而复失，退居小沛，不过吾计划中事罢了。一切，皆为今日。弟自北海救孔融，吾已再留心眼；你素以仁义示人，远播四海；平衡糜竺、陈登、曹豹诸派，稳坐徐州根本；拒袁术僭号，拖延数年，耗其锐气；弟之成绩，智勇兼备，震慑群雄。
  吾本以为弟难敌派系牵制，如吾昔在兖州受张邈、陈宫之累，难成大事。然弟做得极好，远超吾料——能在多方掣肘之下，平衡诸派如此之久，对抗袁术如此之久，皆在吾布局之中，却又超出吾预期。徐州本吾囊中之物，然吕布反复无常，若不除此獠，难成大计。
  近日吕布缺骑，遣人往张扬处重金购良马数百，以壮军势。当然，吾亦缺马，他此举，不过为吾作嫁衣裳罢了。夏侯惇已奉密令，率精骑潜行截夺此批战马。贤弟若有意，可命心腹相助，共取马匹；若不愿，他独力为之，事成马归使君一部。
待良马入手，吕布失其依仗，军心必乱；待时机成熟，吾当亲提精锐南下，与贤弟里应外合，一举荡平吕布。徐州之地，汝与吾共享——
  玄德，操不负汝，望汝勿负操。
                                                                
                                                               操 顿首"
lookdoneDialog = " 小沛信件看完"
dialogue_resource = ExtResource("21_eyp0q")

