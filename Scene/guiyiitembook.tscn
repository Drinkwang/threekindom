[node name="Control4" parent="HBoxContainer" instance=ExtResource("9_6hr8h")]
custom_minimum_size = Vector2(88, 88)
layout_mode = 2
img = ExtResource("10_4th3i")
itemContext = "徐州城郊古坟，阴气森然，夜闻鬼哭，风水术士却称其为“龙脉宝地”。怪矣，城中权贵竞相葬此，墓碑林立，似隐秘谋。或传，坟中藏有不可告人之物，引得大族趋之若鹜。士人对此怪象深病其弊，欲求破解之道。若士族邀你共宴，婉拒探询公务，或能获其信任，托付此事。"
itemstype = 12

[node name="Control5" parent="HBoxContainer" instance=ExtResource("9_6hr8h")]
custom_minimum_size = Vector2(88, 88)
layout_mode = 2
img = ExtResource("12_bd0yj")
itemContext = "城中某富家小姐，夜半出没，貌美如花，却传言嗜血食人。民谣暗唱：“月下红发轻舞，邀约莫回首。”据闻，她曾邀赴宴者，皆未生还，尸骨无存。然怪谈背后，或藏权贵阴谋，抑或妖魅作祟。若欲探寻真相，恐唯有赴宴一途。"
itemstype = 11

[node name="Control6" parent="HBoxContainer" instance=ExtResource("9_6hr8h")]
custom_minimum_size = Vector2(88, 88)
layout_mode = 2
img = ExtResource("11_eapqb")
itemContext = "徐州城外黄帝遗迹，古龙石像巍然屹立，传为黄帝亲铸之神器，内藏无上秘宝。近日，盗墓贼频频觊觎，欲掘遗迹，窃取神器。更闻秘辛，城内军方暗中插手，假借“修缮古迹”之名，行杀良冒功之实，欲掩真相。若欲探黄帝遗迹，需以侠义处之，凭武力慑服士卒，揭开隐秘。"
itemstype = 22

